---
interface Props {
  title: string;
  description: string;
  id?: string;
  href?: string;
}

const { title, description, id, href = "/practice-areas" } = Astro.props;
---

<div class="card" id={id}>
  <div style="margin-bottom: 1.5rem; color: var(--secondary-violet);">
    <slot name="icon" />
  </div>
  <h3 style="margin-bottom: 1rem; color: var(--primary-indigo);">{title}</h3>
  <p style="margin-bottom: 2rem; flex-grow: 1; font-size: 0.95rem; line-height: 1.6;">{description}</p>
  <a href={href} class="nav-link" style="align-self: flex-start; padding: 0; font-weight: 700; font-size: 0.9rem;">
    Pelajari Selengkapnya &rarr;
  </a>
</div>
