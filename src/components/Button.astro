---
interface Props {
  href?: string;
  variant?: 'primary' | 'secondary' | 'outline-white';
  size?: 'sm' | 'md';
  id?: string;
  type?: 'button' | 'submit' | 'reset';
  class?: string;
}

const { 
  href, 
  variant = 'primary', 
  size = 'md', 
  id, 
  type = 'button',
  class: className = '',
  ...rest
} = Astro.props;

const classes = `btn btn-${variant} ${size === 'sm' ? 'btn-sm' : ''} ${className}`;
---

{href ? (
  <a href={href} class={classes} id={id} {...rest}>
    <slot />
  </a>
) : (
  <button type={type} class={classes} id={id} {...rest}>
    <slot />
  </button>
)}
