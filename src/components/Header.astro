---
interface Props {
  activePage?: string;
}

const { activePage = "home" } = Astro.props;

const navItems = [
  { href: "/", label: "Beranda", id: "home" },
  { href: "/about", label: "Tentang Kami", id: "about" },
  { href: "/practice-areas", label: "Bidang Hukum", id: "practice-areas" },
  { href: "/team", label: "Tim Kami", id: "team" },
  { href: "/contact", label: "Hubungi Kami", id: "contact" },
];
---

<header id="site-header">
  <div class="container header-container">
    <!-- Logo -->
    <a href="/" class="logo" id="header-logo">
      <svg class="logo-icon" viewBox="0 0 24 24" aria-hidden="true" xmlns="http://www.w3.org/2000/svg">
        <path d="M12 2L2 5c0 6 3 11.5 10 13.5 7-2 10-7.5 10-13.5L12 2zm0 3.75c1.24 0 2.25 1.01 2.25 2.25S13.24 10.25 12 10.25 9.75 9.24 9.75 8 10.76 5.75 12 5.75zm3.75 7.5c0 1.25-1.5 2.25-3.75 2.25s-3.75-1-3.75-2.25v-.75h7.5v.75z" />
      </svg>
      <span>Basyir Legal</span>
    </a>

    <!-- Checkbox Hack for CSS-Only Mobile Menu -->
    <input type="checkbox" id="menu-toggle" class="menu-toggle" aria-label="Toggle navigation menu" />
    
    <!-- Hamburger Icon -->
    <label for="menu-toggle" class="menu-icon" id="menu-icon-btn">
      <span></span>
      <span></span>
      <span></span>
    </label>

    <!-- Navigation links -->
    <nav id="nav-menu">
      {navItems.map(item => (
        <a 
          href={item.href} 
          class={`nav-link ${activePage === item.id ? 'active' : ''}`}
          id={`nav-link-${item.id}`}
        >
          {item.label}
        </a>
      ))}
      <a href="/contact" class="btn btn-primary btn-sm" style="margin-left: 0.5rem;" id="nav-cta-btn">
        Konsultasi
      </a>
    </nav>
  </div>
</header>
