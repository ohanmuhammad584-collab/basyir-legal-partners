---
interface Props {
  activePage?: string;
}

const { activePage = "home" } = Astro.props;

const navItems = [
  { href: "/", label: "Beranda", id: "home" },
  { href: "/about", label: "Tentang Kami", id: "about" },
  { href: "/practice-areas", label: "Bidang Hukum", id: "practice-areas" },
  { href: "/team", label: "Tim Kami", id: "team" },
  { href: "/konsultasi", label: "Konsultasi AI", id: "konsultasi" },
];
---

<header id="site-header">
  <div class="container header-container">
    <!-- Logo with Image -->
    <a href="/" class="logo" id="header-logo">
      <img src="/images/logo-cortex.png" alt="Legal Cortex Logo" style="width: 2.5rem; height: 2.5rem; border-radius: 50%; object-fit: cover; border: 2px solid rgba(220, 38, 38, 0.4);" />
      <span>Legal Cortex</span>
    </a>

    <!-- Checkbox Hack for CSS-Only Mobile Menu -->
    <input type="checkbox" id="menu-toggle" class="menu-toggle" aria-label="Toggle navigation menu" />
    
    <!-- Hamburger Icon -->
    <label for="menu-toggle" class="menu-icon" id="menu-icon-btn">
      <span></span>
      <span></span>
      <span></span>
    </label>

    <!-- Navigation links -->
    <nav id="nav-menu">
      {navItems.map(item => (
        <a 
          href={item.href} 
          class={`nav-link ${activePage === item.id ? 'active' : ''}`}
          id={`nav-link-${item.id}`}
        >
          {item.label}
        </a>
      ))}
      <a href="/konsultasi" class="btn btn-primary btn-sm" style="margin-left: 0.5rem;" id="nav-cta-btn">
        Konsultasi
      </a>
    </nav>
  </div>
</header>
