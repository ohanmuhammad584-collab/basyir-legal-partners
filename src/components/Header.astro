---
interface Props {
  activePage?: string;
}

const { activePage = "home" } = Astro.props;

const navItems = [
  { href: "/", label: "Beranda", id: "home" },
  { href: "/about", label: "Tentang Kami", id: "about" },
  { href: "/practice-areas", label: "Bidang Hukum", id: "practice-areas" },
  { href: "/team", label: "Tim Kami", id: "team" },
  { href: "/konsultasi", label: "Konsultasi AI", id: "konsultasi" },
];
---

<header id="site-header">
  <div class="container header-container">
    <!-- Logo with Image -->
    <a href="/" class="logo" id="header-logo">
      <img src="/images/logo-cortex.png" alt="Legal Cortex Logo" style="width: 2.5rem; height: 2.5rem; border-radius: 50%; object-fit: cover; border: 2px solid rgba(220, 38, 38, 0.4);" />
      <span>Legal Cortex</span>
    </a>

    <!-- Checkbox Hack for CSS-Only Mobile Menu -->
    <input type="checkbox" id="menu-toggle" class="menu-toggle" aria-label="Toggle navigation menu" />
    
    <!-- Hamburger Icon -->
    <label for="menu-toggle" class="menu-icon" id="menu-icon-btn">
      <span></span>
      <span></span>
      <span></span>
    </label>

    <!-- Navigation links -->
    <nav id="nav-menu">
      {navItems.map(item => (
        <a 
          href={item.href} 
          class={`nav-link ${activePage === item.id ? 'active' : ''}`}
          id={`nav-link-${item.id}`}
        >
          {item.label}
        </a>
      ))}
      <a href="/konsultasi" class="btn btn-primary btn-sm pulse-effect" style="margin-left: 0.5rem; position: relative; overflow: hidden;" id="nav-cta-btn">
        <span style="position: relative; z-index: 1;">Hubungi Kami Langsung</span>
        <div class="shine-effect"></div>
      </a>
    </nav>
  </div>
</header>

<style>
  .pulse-effect {
    box-shadow: 0 0 0 0 rgba(220, 38, 38, 0.7);
    animation: pulse-red 2s infinite;
  }
  
  @keyframes pulse-red {
    0% {
      transform: scale(0.98);
      box-shadow: 0 0 0 0 rgba(220, 38, 38, 0.7);
    }
    70% {
      transform: scale(1);
      box-shadow: 0 0 0 8px rgba(220, 38, 38, 0);
    }
    100% {
      transform: scale(0.98);
      box-shadow: 0 0 0 0 rgba(220, 38, 38, 0);
    }
  }

  .shine-effect {
    position: absolute;
    top: 0;
    left: -100%;
    width: 50%;
    height: 100%;
    background: linear-gradient(to right, rgba(255,255,255,0) 0%, rgba(255,255,255,0.4) 50%, rgba(255,255,255,0) 100%);
    transform: skewX(-25deg);
    animation: shine 3s infinite;
  }
  
  @keyframes shine {
    0% { left: -100%; }
    20% { left: 200%; }
    100% { left: 200%; }
  }
</style>
