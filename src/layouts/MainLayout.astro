---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  activePage?: string;
}

const { title, description = "Firma Hukum Legal Cortex menyediakan solusi hukum bisnis, pidana, perdata, ketenagakerjaan, dan Pengadilan Agama secara profesional, tepercaya, dan berintegritas tinggi di Sumedang.", activePage = "home" } = Astro.props;
---

<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <meta name="generator" content={Astro.generator} />
  
  <!-- SEO Meta Tags -->
  <title>{title} | Legal Cortex</title>
  <meta name="description" content={description} />
  <meta name="robots" content="index, follow" />
  
  <!-- Open Graph / Facebook -->
  <meta property="og:type" content="website" />
  <meta property="og:title" content={`${title} | Legal Cortex`} />
  <meta property="og:description" content={description} />
  
  <!-- Twitter -->
  <meta property="twitter:card" content="summary_large_image" />
  <meta property="twitter:title" content={`${title} | Legal Cortex`} />
  <meta property="twitter:description" content={description} />
</head>
<body>
  <!-- Global SVG definitions for logo gradients -->
  <svg style="position: absolute; width: 0; height: 0; overflow: hidden;" aria-hidden="true">
    <defs>
      <linearGradient id="violet-grad-def" x1="0%" y1="0%" x2="100%" y2="100%">
        <stop offset="0%" stop-color="#991b1b" />
        <stop offset="100%" stop-color="#ef4444" />
      </linearGradient>
    </defs>
  </svg>

  <Header activePage={activePage} />
  
  <slot />
  
  <Footer />

  <script>
    // Global Interactive Click Ripple and Spark Particles Effect
    document.addEventListener('click', (e) => {
      // Don't trigger if click is too close to screen edges to prevent scrollbars or layout shifting
      if (e.clientX < 5 || e.clientY < 5 || e.clientX > window.innerWidth - 5 || e.clientY > window.innerHeight - 5) return;

      // 1. Create main expanding ripple ring
      const ripple = document.createElement('div');
      ripple.className = 'click-ripple';
      ripple.style.left = `${e.clientX}px`;
      ripple.style.top = `${e.clientY}px`;
      document.body.appendChild(ripple);
      
      // 2. Spawn scatter particle sparks
      const particleCount = 6;
      for (let i = 0; i < particleCount; i++) {
        const spark = document.createElement('div');
        spark.className = 'click-spark';
        spark.style.left = `${e.clientX}px`;
        spark.style.top = `${e.clientY}px`;
        
        // Random radial angle and velocity
        const angle = Math.random() * Math.PI * 2;
        const velocity = 25 + Math.random() * 45; // Travel distance in px
        const tx = Math.cos(angle) * velocity;
        const ty = Math.sin(angle) * velocity;
        
        spark.style.setProperty('--tx', `${tx}px`);
        spark.style.setProperty('--ty', `${ty}px`);
        
        // Random spark diameter
        const size = 3 + Math.random() * 3;
        spark.style.width = `${size}px`;
        spark.style.height = `${size}px`;
        
        document.body.appendChild(spark);
        
        // Cleanup particle
        setTimeout(() => {
          spark.remove();
        }, 600);
      }
      
      // Cleanup ripple
      setTimeout(() => {
        ripple.remove();
      }, 500);
    });
  </script>
</body>
</html>
