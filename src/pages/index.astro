---
import MainLayout from '../layouts/MainLayout.astro';
import Button from '../components/Button.astro';
---

<MainLayout title="Beranda" activePage="home">
  <!-- Hero Section -->
  <section style="background: linear-gradient(to bottom, rgba(10,10,10,0.82), rgba(17,17,17,0.98)), url('/images/lobby-cortex.png') center/cover no-repeat; color: var(--text-light); padding: 9rem 0 8rem 0; position: relative; border-bottom: 1px solid var(--border-color);">
    <!-- Visual decorative meshes for wow factor -->
    <div class="glow-mesh glow-mesh-1"></div>
    <div class="glow-mesh glow-mesh-2" style="opacity: 0.6;"></div>
    
    <div class="container" style="position: relative; z-index: 1;">
      <div style="max-width: 850px; margin: 0 auto; text-align: center;">
        <span class="badge" style="background-color: rgba(220, 38, 38, 0.15); color: var(--secondary-violet-light); font-weight: 700; align-self: center;">
          Firma Hukum Spesialis Litigasi & Hukum Keluarga
        </span>
        <h1 style="color: var(--text-light); font-size: clamp(2.5rem, 5vw, 4.25rem); margin-bottom: 1.5rem; line-height: 1.15; font-weight: 800; letter-spacing: -0.04em;">
          Navigasi Hukum Berwibawa, <span style="background: var(--violet-gradient); -webkit-background-clip: text; -webkit-text-fill-color: transparent;">Solusi Keadilan Nyata</span>
        </h1>
        <p style="color: var(--text-light-muted); font-size: clamp(1.1rem, 2vw, 1.25rem); margin-bottom: 3rem; line-height: 1.7; font-weight: 400; max-width: 750px; margin-left: auto; margin-right: auto;">
          Legal Cortex menghadirkan pembelaan hukum yang tajam, berintegritas, dan berwibawa. Kami mendampingi Anda menyelesaikan perkara perdata, pidana, sengketa bisnis, serta penyelesaian kasus di Pengadilan Agama.
        </p>
        <div style="display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap;">
          <Button href="/konsultasi" variant="primary" id="hero-cta-primary">
            Konsultasi Sekarang
            <svg style="width: 1.25rem; height: 1.25rem; fill: currentColor;" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
              <path d="M5 13h11.86l-5.43 5.43 1.42 1.42L21.14 12l-8.29-8.29-1.42 1.42L16.86 11H5v2z"/>
            </svg>
          </Button>
          <Button href="/practice-areas" variant="outline-white" id="hero-cta-secondary">
            Pelajari Layanan
          </Button>
        </div>
      </div>
    </div>
  </section>

  <!-- Core Values Section -->
  <section style="background-color: var(--bg-light);">
    <div class="container">
      <div style="text-align: center; max-width: 600px; margin: 0 auto 4rem auto;">
        <span class="badge" style="align-self: center;">Keunggulan Kami</span>
        <h2 style="color: var(--text-light); margin-bottom: 1rem;">Mengapa Memilih Kami?</h2>
        <p style="color: var(--text-dark-muted);">Komitmen utama kami dalam menegakkan keadilan serta melindungi kepentingan hukum Anda secara profesional.</p>
      </div>

      <div class="card-grid">
        <!-- Value 1 -->
        <div class="card" id="value-integrity" style="border-color: var(--border-color);">
          <div style="width: 3.5rem; height: 3.5rem; border-radius: var(--radius-md); background: rgba(220, 38, 38, 0.1); display: flex; align-items: center; justify-content: center; margin-bottom: 1.5rem; color: var(--secondary-violet);">
            <!-- Scale Icon -->
            <svg style="width: 2rem; height: 2rem; fill: currentColor;" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
              <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 17h-2v-2h2v2zm2.07-7.75l-.9.92C13.45 12.9 13 13.5 13 15h-2v-.5c0-1.1.45-2.1 1.17-2.83l1.24-1.26c.37-.36.59-.86.59-1.41 0-1.1-.9-2-2-2s-2 .9-2 2H7c0-2.76 2.24-5 5-5s5 2.24 5 5c0 1.04-.42 1.99-1.07 2.75z"/>
            </svg>
          </div>
          <h3 style="margin-bottom: 1rem; color: var(--text-light);">Integritas & Kepercayaan</h3>
          <p style="font-size: 0.95rem; line-height: 1.6; color: var(--text-dark-muted);">Kami menjunjung tinggi etika profesi advokat dengan transparansi penuh. Klien selalu mendapatkan analisis hukum yang jujur, objektif, dan realistis atas kasusnya.</p>
        </div>

        <!-- Value 2 -->
        <div class="card" id="value-expertise" style="border-color: var(--border-color);">
          <div style="width: 3.5rem; height: 3.5rem; border-radius: var(--radius-md); background: rgba(220, 38, 38, 0.1); display: flex; align-items: center; justify-content: center; margin-bottom: 1.5rem; color: var(--secondary-violet);">
            <!-- Award Icon -->
            <svg style="width: 2rem; height: 2rem; fill: currentColor;" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
              <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 17h-2v-6h2v6zm0-8h-2V7h2v4z"/>
            </svg>
          </div>
          <h3 style="margin-bottom: 1rem; color: var(--text-light);">Pendekatan Hukum Tajam</h3>
          <p style="font-size: 0.95rem; line-height: 1.6; color: var(--text-dark-muted);">Dengan pengalaman mendalam di bidang litigasi pengadilan umum maupun Pengadilan Agama, kami menyusun berkas gugatan dan bukti-bukti secara cermat demi hasil maksimal.</p>
        </div>

        <!-- Value 3 -->
        <div class="card" id="value-solutions" style="border-color: var(--border-color);">
          <div style="width: 3.5rem; height: 3.5rem; border-radius: var(--radius-md); background: rgba(220, 38, 38, 0.1); display: flex; align-items: center; justify-content: center; margin-bottom: 1.5rem; color: var(--secondary-violet);">
            <!-- Target Icon -->
            <svg style="width: 2rem; height: 2rem; fill: currentColor;" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
              <path d="M12 2A10 10 0 002 12a10 10 0 0010 10 10 10 0 0010-10A10 10 0 0012 2zm0 18c-4.41 0-8-3.59-8-8s3.59-8 8-8 8 3.59 8 8-3.59 8-8 8zm-1-13h2v6h-2zm0 8h2v2h-2z"/>
            </svg>
          </div>
          <h3 style="margin-bottom: 1rem; color: var(--text-light);">Fokus Solusi Damai & Cepat</h3>
          <p style="font-size: 0.95rem; line-height: 1.6; color: var(--text-dark-muted);">Kami mengutamakan jalur mediasi yang efisien untuk meminimalkan beban emosional dan biaya finansial bagi Anda, tanpa mengurangi hak hukum yang wajib diterima.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Mini About Section -->
  <section style="background-color: var(--bg-light-card); border-top: 1px solid var(--border-color);">
    <div class="container">
      <div class="responsive-grid-2">
        <!-- Left Side: Visual Illustration (CSS Isometric Element) -->
        <div style="position: relative; height: 380px; display: flex; align-items: center; justify-content: center;" id="about-visual-container">
          <!-- Main isometric block -->
          <div style="
            width: 260px;
            height: 260px;
            background: var(--violet-gradient);
            border-radius: var(--radius-lg);
            transform: rotate(-15deg) skew(15deg);
            box-shadow: 25px 25px 50px rgba(220, 38, 38, 0.2);
            display: flex;
            align-items: center;
            justify-content: center;
            position: relative;
          ">
            <!-- Overlay card -->
            <div style="
              position: absolute;
              top: -30px;
              left: -30px;
              width: 100%;
              height: 100%;
              background-color: #141414;
              border: 1px solid var(--border-color);
              border-radius: var(--radius-lg);
              display: flex;
              flex-direction: column;
              justify-content: space-between;
              padding: 2rem;
              color: var(--text-light);
              box-shadow: var(--shadow-colored);
            ">
              <svg style="width: 3rem; height: 3rem; fill: var(--secondary-violet);" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                <path d="M12 2L2 5c0 6 3 11.5 10 13.5 7-2 10-7.5 10-13.5L12 2z"/>
              </svg>
              <div>
                <h4 style="color: var(--text-light); margin-bottom: 0.25rem;">Legal Cortex</h4>
                <p style="color: var(--text-dark-muted); font-size: 0.85rem;">Trust, Integrity & Excellence</p>
              </div>
            </div>
          </div>
        </div>

        <!-- Right Side: Content -->
        <div>
          <span class="badge">Tentang Kantor Hukum</span>
          <h2 style="color: var(--text-light); margin-bottom: 1.5rem; font-size: 2.25rem;">Berkomitmen Penuh Terhadap Hak Hukum Anda</h2>
          <p style="margin-bottom: 1.5rem; font-size: 1.05rem; line-height: 1.7; color: var(--text-dark-muted);">
            Legal Cortex didirikan untuk menjawab tingginya kebutuhan akan advokat yang berintegritas dan tangguh di Sumedang dan sekitarnya. Kami percaya perlindungan hukum terbaik lahir dari analisis taktis yang mendalam.
          </p>
          <p style="margin-bottom: 2.5rem; font-size: 0.95rem; line-height: 1.7; color: var(--text-dark-muted);">
            Kami memadukan penguasaan regulasi lokal dengan profesionalisme berstandar tinggi untuk menyusun strategi penyelesaian kasus litigasi maupun non-litigasi yang tajam dan taktis.
          </p>
          <Button href="/about" variant="secondary" id="about-read-more" style="border-color: var(--border-color);">
            Pelajari Rekam Jejak Kami
          </Button>
        </div>
      </div>
    </div>
  </section>

  <!-- Case Success Portfolio (Track Record) Section -->
  <section style="background-color: var(--bg-light); border-top: 1px solid var(--border-color);">
    <div class="container">
      <div style="text-align: center; max-width: 700px; margin: 0 auto 4rem auto;">
        <span class="badge" style="align-self: center;">Hasil & Rekam Jejak</span>
        <h2 style="color: var(--text-light); margin-bottom: 1rem;">Bukti Penyelesaian Kasus Sukses</h2>
        <p style="color: var(--text-dark-muted);">Komitmen kami nyata. Klik setiap kartu untuk melihat detail arsip penyelesaian perkara.</p>
      </div>

      <!-- Stats Grid -->
      <div class="card-grid" style="grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); margin-bottom: 4rem; text-align: center;">
        <div class="card" style="padding: 2.5rem 2rem; border-color: var(--border-color); align-items: center;">
          <span style="font-size: 3.5rem; font-weight: 800; color: var(--secondary-violet); display: block; margin-bottom: 0.5rem; line-height: 1;">98%</span>
          <h4 style="color: var(--text-light); margin-bottom: 0.5rem; font-size: 1.1rem;">Kasus Sukses</h4>
          <p style="font-size: 0.85rem; color: var(--text-dark-muted); line-height: 1.4;">Tingkat keberhasilan penyelesaian hukum memuaskan.</p>
        </div>
        <div class="card" style="padding: 2.5rem 2rem; border-color: var(--border-color); align-items: center;">
          <span style="font-size: 3.5rem; font-weight: 800; color: var(--secondary-violet); display: block; margin-bottom: 0.5rem; line-height: 1;">150+</span>
          <h4 style="color: var(--text-light); margin-bottom: 0.5rem; font-size: 1.1rem;">Kasus Selesai</h4>
          <p style="font-size: 0.85rem; color: var(--text-dark-muted); line-height: 1.4;">Perkara Pengadilan Agama & Perdata berhasil diselesaikan.</p>
        </div>
        <div class="card" style="padding: 2.5rem 2rem; border-color: var(--border-color); align-items: center;">
          <span style="font-size: 3.5rem; font-weight: 800; color: var(--secondary-violet); display: block; margin-bottom: 0.5rem; line-height: 1;">Rp 50M+</span>
          <h4 style="color: var(--text-light); margin-bottom: 0.5rem; font-size: 1.1rem;">Aset Terlindungi</h4>
          <p style="font-size: 0.85rem; color: var(--text-dark-muted); line-height: 1.4;">Hak waris & harta bersama (gono-gini) berhasil diamankan.</p>
        </div>
      </div>

      <!-- Asset Gallery -->
      <div style="text-align: center; margin-bottom: 1.5rem;">
        <h3 style="color: var(--accent-gold-premium); font-size: 1.25rem; font-weight: 700; margin-bottom: 0.5rem;">Portofolio Aset yang Berhasil Dilindungi</h3>
        <p style="color: var(--text-dark-muted); font-size: 0.9rem;">Contoh aset klien yang berhasil diamankan melalui proses hukum kami.</p>
      </div>
      <div class="asset-gallery">
        <div class="asset-card">
          <img src="/images/asset-office.png" alt="Ruko Komersial Jatinangor" loading="lazy" />
          <div class="asset-card-info">
            <h4>Ruko Komersial — Jatinangor</h4>
            <p>Sengketa Waris • Rp 1.8 M • 2024</p>
          </div>
        </div>
        <div class="asset-card">
          <img src="/images/asset-house.png" alt="Rumah Tinggal Sumedang" loading="lazy" />
          <div class="asset-card-info">
            <h4>Rumah Tinggal — Sumedang Selatan</h4>
            <p>Harta Gono-Gini • Rp 2.1 M • 2025</p>
          </div>
        </div>
        <div class="asset-card">
          <img src="/images/asset-land.png" alt="Lahan Pertanian Ujungjaya" loading="lazy" />
          <div class="asset-card-info">
            <h4>Lahan Pertanian — Ujungjaya</h4>
            <p>Sertifikat Tanah • Rp 950 Jt • 2024</p>
          </div>
        </div>
      </div>

      <!-- Case Studies List (Clickable) -->
      <div class="card-grid" style="margin-top: 4rem;">
        <!-- Case 1 -->
        <div class="card case-clickable" data-case="1" style="border-color: var(--border-color); position: relative; overflow: hidden; padding: 2.25rem 2rem;">
          <span class="badge" style="background-color: rgba(220, 38, 38, 0.15); color: var(--secondary-violet-light); font-size: 0.75rem; margin-bottom: 1.25rem;">Pengadilan Agama Sumedang</span>
          <h3 style="margin-bottom: 1rem; color: var(--text-light); font-size: 1.35rem; line-height: 1.3;">Penyelesaian Hak Asuh & Nafkah Anak</h3>
          <p style="font-size: 0.9rem; line-height: 1.6; color: var(--text-dark-muted); margin-bottom: 2rem; flex-grow: 1;">Berhasil memenangkan hak asuh penuh atas dua anak bagi klien serta menetapkan nafkah bulanan yang memadai pasca-perceraian.</p>
          <div style="font-size: 0.85rem; font-weight: 700; color: var(--secondary-violet); display: flex; align-items: center; gap: 0.5rem; border-top: 1px solid var(--border-color); padding-top: 1rem; width: 100%;">
            <svg style="width: 1.1rem; height: 1.1rem; fill: currentColor; flex-shrink: 0;" viewBox="0 0 24 24"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/></svg>
            <span>Klik untuk Lihat Detail Arsip</span>
          </div>
        </div>

        <!-- Case 2 -->
        <div class="card case-clickable" data-case="2" style="border-color: var(--border-color); position: relative; overflow: hidden; padding: 2.25rem 2rem;">
          <span class="badge" style="background-color: rgba(220, 38, 38, 0.15); color: var(--secondary-violet-light); font-size: 0.75rem; margin-bottom: 1.25rem;">Mediasi Sengketa Waris</span>
          <h3 style="margin-bottom: 1rem; color: var(--text-light); font-size: 1.35rem; line-height: 1.3;">Pembagian Warisan Tanah & Ruko</h3>
          <p style="font-size: 0.9rem; line-height: 1.6; color: var(--text-dark-muted); margin-bottom: 2rem; flex-grow: 1;">Menyelesaikan sengketa warisan keluarga senilai Rp 3.2 Milyar melalui mediasi damai secara kekeluargaan.</p>
          <div style="font-size: 0.85rem; font-weight: 700; color: var(--secondary-violet); display: flex; align-items: center; gap: 0.5rem; border-top: 1px solid var(--border-color); padding-top: 1rem; width: 100%;">
            <svg style="width: 1.1rem; height: 1.1rem; fill: currentColor; flex-shrink: 0;" viewBox="0 0 24 24"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/></svg>
            <span>Klik untuk Lihat Detail Arsip</span>
          </div>
        </div>

        <!-- Case 3 -->
        <div class="card case-clickable" data-case="3" style="border-color: var(--border-color); position: relative; overflow: hidden; padding: 2.25rem 2rem;">
          <span class="badge" style="background-color: rgba(220, 38, 38, 0.15); color: var(--secondary-violet-light); font-size: 0.75rem; margin-bottom: 1.25rem;">Gugatan Harta Bersama</span>
          <h3 style="margin-bottom: 1rem; color: var(--text-light); font-size: 1.35rem; line-height: 1.3;">Penyelamatan Aset Gono-Gini</h3>
          <p style="font-size: 0.9rem; line-height: 1.6; color: var(--text-dark-muted); margin-bottom: 2rem; flex-grow: 1;">Mengamankan ruko operasional usaha dan tabungan bersama senilai ratusan juta rupiah yang diklaim sepihak oleh pihak lawan.</p>
          <div style="font-size: 0.85rem; font-weight: 700; color: var(--secondary-violet); display: flex; align-items: center; gap: 0.5rem; border-top: 1px solid var(--border-color); padding-top: 1rem; width: 100%;">
            <svg style="width: 1.1rem; height: 1.1rem; fill: currentColor; flex-shrink: 0;" viewBox="0 0 24 24"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/></svg>
            <span>Klik untuk Lihat Detail Arsip</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Case Archive Modal -->
  <div class="case-modal-overlay" id="caseModal">
    <div class="case-modal">
      <button class="case-modal-close" id="caseModalClose">&times;</button>
      <span class="case-archive-number" id="modalArchiveNo"></span>
      <h3 class="case-modal-title" id="modalTitle"></h3>
      
      <div style="border-top: 1px solid rgba(197, 160, 89, 0.2); padding-top: 1.5rem; margin-top: 0.5rem;">
        <div class="case-detail-row">
          <span class="case-detail-label">Klien</span>
          <span class="case-detail-value" id="modalClient"></span>
        </div>
        <div class="case-detail-row">
          <span class="case-detail-label">Masalah</span>
          <span class="case-detail-value" id="modalProblem"></span>
        </div>
        <div class="case-detail-row">
          <span class="case-detail-label">Strategi</span>
          <span class="case-detail-value" id="modalStrategy"></span>
        </div>
        <div class="case-detail-row">
          <span class="case-detail-label">Hasil</span>
          <span class="case-detail-value" id="modalResult" style="color: #22c55e; font-weight: 700;"></span>
        </div>
        <div class="case-detail-row">
          <span class="case-detail-label">Advokat</span>
          <span class="case-detail-value" id="modalLawyer" style="color: var(--accent-gold-premium); font-weight: 600;"></span>
        </div>
      </div>
    </div>
  </div>

  <!-- CTA Section -->
  <section style="background: var(--indigo-gradient); color: var(--text-light); text-align: center; padding: 6.5rem 0; border-top: 1px solid var(--border-color);">
    <div class="container">
      <div style="max-width: 750px; margin: 0 auto;">
        <h2 style="color: var(--text-light); margin-bottom: 1.5rem; font-size: 2.25rem;">Selesaikan Permasalahan Hukum Anda Hari Ini</h2>
        <p style="color: var(--text-light-muted); margin-bottom: 2.5rem; font-size: 1.1rem; line-height: 1.6;">
          Tunda kekhawatiran Anda. Konsultasikan kasus Anda secara privat dengan advokat ahli kami guna menyusun strategi hukum yang kokoh.
        </p>
        <Button href="/contact" variant="primary" style="background: var(--violet-gradient); color: #ffffff; box-shadow: 0 15px 30px rgba(220, 38, 38, 0.25);" id="cta-contact-btn">
          Hubungi Kami via WhatsApp
        </Button>
      </div>
    </div>
  </section>

  <!-- Case Modal Script -->
  <script>
    const caseData = {
      1: {
        archiveNo: "LC/2025/PA-042",
        title: "Penyelesaian Hak Asuh & Nafkah Anak",
        client: "Ibu R.S. (34 tahun, ibu rumah tangga, Sumedang Selatan)",
        problem: "Klien mengajukan cerai gugat terhadap suami yang melalaikan kewajiban nafkah selama 2 tahun dan melakukan kekerasan verbal. Suami menolak memberikan hak asuh kedua anak (usia 4 dan 7 tahun) serta menuntut pembagian harta gono-gini secara sepihak.",
        strategy: "Tim Legal Cortex menyusun gugatan cerai beserta permohonan hak asuh (hadhanah) bersamaan. Bukti-bukti penelantaran nafkah, catatan KDRT dari laporan RT/RW, serta saksi tetangga dipersiapkan secara rinci. Mediasi pertama gagal, namun di persidangan berhasil dibuktikan bahwa klien lebih layak memegang hak asuh berdasarkan usia anak dan kedekatan emosional.",
        result: "Gugatan dikabulkan penuh. Hak asuh kedua anak jatuh kepada klien. Mantan suami diwajibkan membayar nafkah anak Rp 3.500.000/bulan + biaya pendidikan. Putusan telah inkrah.",
        lawyer: "Dr. Ohan M Basyir, S.H., M.H. — Founder & Managing Partner"
      },
      2: {
        archiveNo: "LC/2024/MED-018",
        title: "Pembagian Warisan Tanah & Ruko Keluarga",
        client: "Bpk. D.K. & Keluarga (7 ahli waris, Jatinangor)",
        problem: "Almarhum pemilik aset meninggalkan 3 bidang tanah (total 2.400 m²), 2 unit ruko di Jatinangor, dan tabungan sebesar Rp 480 juta, tanpa wasiat. Perselisihan muncul karena 2 ahli waris menguasai sertifikat secara sepihak dan menolak membagi warisan sesuai porsi hukum Islam (faraid).",
        strategy: "Legal Cortex melakukan inventarisasi lengkap terhadap seluruh aset warisan. Kami memfasilitasi mediasi 3 putaran dengan seluruh ahli waris, menggunakan perhitungan faraid yang presisi. Setelah putaran kedua, kami menyusun draft Akta Perdamaian yang disepakati oleh seluruh pihak.",
        result: "Kesepakatan damai tercapai tanpa sidang pengadilan. Seluruh aset senilai Rp 3.2 Milyar berhasil dibagi sesuai hukum faraid. Akta Perdamaian disahkan oleh Pengadilan Agama. Hubungan keluarga tetap terjaga baik.",
