<MainLayout title="Tim Pengacara" activePage="team" description="Profil pengacara dan partner hukum utama di Legal Cortex. Didukung oleh praktisi hukum berpengalaman, ahli, dan berintegritas.">
  <!-- Page Header -->
  <section style="background: var(--dark-gradient); color: var(--text-light); padding: 5rem 0; border-bottom: 1px solid var(--border-color);">
    <div class="glow-mesh glow-mesh-1" style="opacity: 0.3;"></div>
    <div class="container" style="position: relative; z-index: 1;">
      <span class="badge" style="background-color: rgba(220, 38, 38, 0.15); color: var(--secondary-violet-light);">Advokat & Partner</span>
      <h1 style="color: var(--text-light); font-size: 3rem; margin-bottom: 1rem;">Tim Pengacara Kami</h1>
      <p style="color: var(--text-light-muted); max-width: 600px; font-size: 1.1rem;">Berkenalan dengan tim pengacara profesional yang berdedikasi tinggi menjaga hak dan kepatuhan hukum Anda.</p>
    </div>
  </section>

  <!-- Team Grid Section -->
  <section style="background-color: var(--bg-light);">
    <div class="container">
      <div class="card-grid" style="grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));">
        
        {lawyers.map(lawyer => (
          <TeamCard 
            name={lawyer.name}
            role={lawyer.role}
            specialty={lawyer.specialty}
            email={lawyer.email}
            phone={lawyer.phone}
            nip={lawyer.nip}
            image={lawyer.image}
            description={lawyer.description}
            education={lawyer.education}
            id={lawyer.id}
          />
        ))}

      </div>
    </div>
  </section>

  <!-- Team CTA -->
  <section style="background-color: var(--bg-light-card); border-top: 1px solid var(--border-color); text-align: center;">
    <div class="container">
      <div style="max-width: 650px; margin: 0 auto;">
        <h2 style="color: var(--text-light); margin-bottom: 1.5rem;">Ingin Bergabung atau Berkonsultasi Langsung?</h2>
        <p style="margin-bottom: 2.5rem; color: var(--text-dark-muted);">Kami percaya pada kolaborasi dan dedikasi penuh untuk membela hak klien. Silakan klik tombol di bawah untuk berkonsultasi dengan asisten hukum AI kami sebelum dijadwalkan pertemuan privat dengan salah satu partner kami.</p>
        <Button href="/konsultasi" variant="primary" id="team-cta-btn">Konsultasi Sekarang</Button>
      </div>
    </div>
  </section>
</MainLayout>
